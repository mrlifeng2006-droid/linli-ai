# 邻里AI V17.0 环境配置
# 复制此文件为 .env 并填写实际值

# ========== 服务器配置 ==========
PORT=3000
NODE_ENV=development

# ========== 数据库配置 ==========
DB_HOST=localhost
DB_PORT=3306
DB_NAME=linli_ai
DB_USER=root
DB_PASSWORD=your_password_here

# ========== Redis配置 ==========
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ========== JWT配置 ==========
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# ========== DeepSeek AI配置 ==========
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions
DEEPSEEK_MODEL=deepseek-chat

# ========== 腾讯云COS配置 ==========
COS_SECRET_ID=your_cos_secret_id_here
COS_SECRET_KEY=your_cos_secret_key_here
COS_BUCKET=linli-ai-video-1250000000
COS_REGION=ap-guangzhou
COS_URL=https://linli-ai-video-1250000000.cos.ap-guangzhou.myqcloud.com

# ========== FFmpeg配置 ==========
FFMPEG_PATH=ffmpeg
FFMPEG_STATIC_PATH=D:\tools\ffmpeg\bin\ffmpeg.exe

# ========== 微信小程序配置 ==========
WECHAT_APPID=your_wechat_appid_here
WECHAT_SECRET=your_wechat_secret_here

# ========== 微信支付配置 ==========
WECHAT_PAY_MCHID=your_mchid_here
WECHAT_PAY_API_KEY=your_wechat_pay_api_key_here
WECHAT_PAY_NOTIFY_URL=https://your-domain.com/api/payment/notify

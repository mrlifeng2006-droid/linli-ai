/* 邻里AI 全局样式 */
page {
  --theme-color: #FF6B00;
  --theme-color-light: #FFF3E0;
  --bg-color: #F5F5F5;
  --text-color: #333333;
  --text-color-light: #666666;
  --text-color-gray: #999999;
  --border-color: #E5E5E5;
  --white: #FFFFFF;
  --success: #07C160;
  --danger: #FF4D4F;
  --warning: #FFB800;

  background-color: var(--bg-color);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  font-size: 28rpx;
  color: var(--text-color);
  line-height: 1.6;
}

/* 通用工具类 */
.flex { display: flex; }
.flex-col { flex-direction: column; }
.flex-center { align-items: center; justify-content: center; }
.flex-between { justify-content: space-between; }
.flex-wrap { flex-wrap: wrap; }
.flex-1 { flex: 1; }

.text-center { text-align: center; }
.text-primary { color: var(--theme-color); }
.text-success { color: var(--success); }
.text-danger { color: var(--danger); }
.text-warning { color: var(--warning); }
.text-gray { color: var(--text-color-gray); }
.text-light { color: var(--text-color-light); }
.text-bold { font-weight: bold; }
.text-sm { font-size: 24rpx; }
.text-lg { font-size: 36rpx; }
.text-xl { font-size: 44rpx; }

.mt-10 { margin-top: 10rpx; }
.mt-20 { margin-top: 20rpx; }
.mt-30 { margin-top: 30rpx; }
.mt-40 { margin-top: 40rpx; }
.mb-20 { margin-bottom: 20rpx; }
.mb-30 { margin-bottom: 30rpx; }
.p-20 { padding: 20rpx; }
.p-30 { padding: 30rpx; }

.bg-white { background-color: var(--white); }
.bg-primary { background-color: var(--theme-color); }
.radius-10 { border-radius: 10rpx; }
.radius-20 { border-radius: 20rpx; }

/* 按钮 */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 500;
  transition: all 0.2s;
}

.btn-primary {
  background: linear-gradient(135deg, #FF8C00, #FF6B00);
  color: white;
  box-shadow: 0 4rpx 20rpx rgba(255, 107, 0, 0.3);
}

.btn-primary:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.btn-outline {
  border: 2rpx solid var(--theme-color);
  color: var(--theme-color);
  background: transparent;
}

.btn-disabled {
  background: #CCCCCC;
  color: white;
  box-shadow: none;
}

/* 卡片 */
.card {
  background: var(--white);
  border-radius: 20rpx;
  padding: 30rpx;
  margin: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  color: var(--text-color-gray);
}

.empty-icon { font-size: 120rpx; margin-bottom: 20rpx; }

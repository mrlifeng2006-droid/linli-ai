/* 首页样式 */
.container {
  min-height: 100vh;
  background: #F5F5F5;
}

/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  background: #FF6B00;
  gap: 20rpx;
}

.search-input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.2);
  border-radius: 40rpx;
  padding: 0 30rpx;
  height: 72rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: white;
  margin-left: 10rpx;
}

.location-wrap {
  display: flex;
  align-items: center;
  color: white;
  font-size: 26rpx;
  white-space: nowrap;
}

/* 轮播图 */
.banner-swiper {
  height: 300rpx;
  background: white;
}

.banner-img {
  width: 100%;
  height: 100%;
}

/* 功能入口 */
.entry-grid {
  display: flex;
  flex-wrap: wrap;
  background: white;
  padding: 30rpx 0;
  margin-bottom: 20rpx;
}

.entry-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.entry-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 50rpx;
}

.entry-name {
  font-size: 26rpx;
  color: #333;
}

/* 商家列表 */
.section {
  background: white;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

.section-more {
  font-size: 26rpx;
  color: #999;
}

.merchant-card {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.merchant-card:last-child {
  border-bottom: none;
}

.merchant-cover {
  width: 180rpx;
  height: 140rpx;
  border-radius: 12rpx;
  background: #EEE;
  flex-shrink: 0;
}

.merchant-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.merchant-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.merchant-desc {
  font-size: 26rpx;
  color: #666;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.merchant-tags {
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
}

.tag {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  background: #FFF3E0;
  color: #FF6B00;
  border-radius: 20rpx;
}

/* AI横幅 */
.ai-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, #FF8C00, #FF6B00);
  margin: 20rpx;
  padding: 40rpx;
  border-radius: 20rpx;
  color: white;
}

.ai-title {
  font-size: 36rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 10rpx;
}

.ai-desc {
  font-size: 26rpx;
  opacity: 0.9;
}

.ai-btn {
  background: white;
  color: #FF6B00;
  padding: 16rpx 32rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: bold;
  flex-shrink: 0;
}

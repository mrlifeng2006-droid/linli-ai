/* pages/login/login.wxss */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF3E0 0%, #FFFFFF 40%);
  padding: 0 50rpx;
}

/* Logo区 */
.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
  padding-bottom: 60rpx;
}

.logo-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

.app-name {
  font-size: 52rpx;
  font-weight: bold;
  color: #FF6B00;
  margin-bottom: 10rpx;
}

.app-slogan {
  font-size: 28rpx;
  color: #999999;
}

/* 表单区 */
.form-section {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 50rpx 40rpx;
  box-shadow: 0 4rpx 30rpx rgba(0, 0, 0, 0.06);
}

.form-item {
  margin-bottom: 40rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background: #F5F5F5;
  border-radius: 16rpx;
  padding: 0 30rpx;
  font-size: 32rpx;
  box-sizing: border-box;
}

/* 验证码行 */
.code-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.code-input {
  flex: 1;
}

.code-btn {
  flex-shrink: 0;
  width: 220rpx;
  height: 88rpx;
  background: linear-gradient(135deg, #FF8C00, #FF6B00);
  color: white;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 500;
}

.code-btn:active {
  opacity: 0.85;
}

.code-btn.disabled {
  background: #CCCCCC;
  color: white;
}

/* 登录按钮 */
.login-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #FF8C00, #FF6B00);
  color: white;
  border-radius: 48rpx;
  font-size: 34rpx;
  font-weight: bold;
  border: none;
  box-shadow: 0 6rpx 24rpx rgba(255, 107, 0, 0.35);
  margin-top: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-btn::after {
  border: none;
}

.login-btn[disabled] {
  background: #CCCCCC;
  box-shadow: none;
  color: white;
}

/* 注册入口 */
.register-link {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-top: 40rpx;
  font-size: 28rpx;
  color: #999999;
}

.link {
  color: #FF6B00;
  margin: 0 6rpx;
}

/* 底部说明 */
.footer {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-top: 60rpx;
  padding-bottom: 60rpx;
  font-size: 24rpx;
  color: #BBBBBB;
}

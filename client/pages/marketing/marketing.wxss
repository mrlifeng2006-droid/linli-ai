/* pages/marketing/marketing.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}
.header {
  padding: 40rpx 30rpx 30rpx;
  background: linear-gradient(135deg, #ff6b35, #ff9a6c);
  color: #fff;
}
.header-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}
.header-sub {
  display: block;
  font-size: 26rpx;
  opacity: 0.85;
}

/* 工具网格 */
.tool-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 24rpx 20rpx;
  gap: 20rpx;
  margin-top: -30rpx;
}
.tool-card {
  width: calc(50% - 10rpx);
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
  box-sizing: border-box;
}
.tool-icon {
  font-size: 56rpx;
  margin-bottom: 16rpx;
}
.tool-name {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}
.tool-desc {
  display: block;
  font-size: 22rpx;
  color: #999;
}

/* 区块 */
.section {
  margin: 24rpx 30rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
}
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}
.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}
.section-more {
  font-size: 24rpx;
  color: #ff6b35;
}

/* 活动卡片 */
.activity-card {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #fafafa;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}
.activity-info { flex: 1; }
.activity-name {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}
.activity-meta {
  display: block;
  font-size: 22rpx;
  color: #999;
}
.activity-stats {
  text-align: center;
  margin: 0 20rpx;
}
.stat-label {
  display: block;
  font-size: 20rpx;
  color: #999;
  margin-bottom: 4rpx;
}
.stat-val {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}
.activity-status {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  background: #fff3ee;
  color: #ff6b35;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 40rpx;
}
.empty-icon { font-size: 80rpx; display: block; margin-bottom: 20rpx; }
.empty-text { font-size: 28rpx; color: #999; display: block; margin-bottom: 24rpx; }
.empty-btn {
  display: inline-block;
  padding: 16rpx 48rpx;
  background: #ff6b35;
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
}

/* GEO数据 */
.geo-summary {
  display: flex;
  justify-content: space-around;
  margin-bottom: 20rpx;
}
.geo-item { text-align: center; }
.geo-num {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: #ff6b35;
  margin-bottom: 8rpx;
}
.geo-label {
  display: block;
  font-size: 22rpx;
  color: #999;
}
.geo-tip {
  background: #fff9e6;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 24rpx;
  color: #996600;
  text-align: center;
}

.float-btn {
  position: fixed;
  bottom: 40rpx;
  right: 40rpx;
  width: 240rpx;
  height: 88rpx;
  background: linear-gradient(135deg, #FF8C00, #FF6B00);
  color: white;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(255, 107, 0, 0.4);
  z-index: 100;
}
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 200;
  display: none;
  opacity: 0;
  transition: opacity 0.3s;
}
.modal-mask.show { display: block; opacity: 1; }
.modal-box {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  background: white;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx 40rpx 60rpx;
  z-index: 300;
  transform: translateY(100%);
  transition: transform 0.3s;
}
.modal-box.show { transform: translateY(0); }
.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-bottom: 40rpx;
}
.modal-item { margin-bottom: 30rpx; }
.modal-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 12rpx;
}
.modal-input {
  width: 100%;
  height: 80rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  box-sizing: border-box;
}
.modal-input-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.modal-input-row .modal-input { flex: 1; }
.flex1 { flex: 1; }
.input-suffix { font-size: 28rpx; color: #666; white-space: nowrap; }
.modal-picker {
  height: 80rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 30rpx;
}
.arrow { font-size: 32rpx; color: #ccc; }
.modal-btns {
  display: flex;
  gap: 24rpx;
  margin-top: 40rpx;
}
.modal-cancel {
  flex: 1;
  height: 88rpx;
  background: #f0f0f0;
  border-radius: 44rpx;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #666;
}
.modal-confirm {
  flex: 1;
  height: 88rpx;
  background: linear-gradient(135deg, #FF8C00, #FF6B00);
  border-radius: 44rpx;
  font-size: 32rpx;

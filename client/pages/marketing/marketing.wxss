/* pages/marketing/marketing.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}
.header {
  padding: 40rpx 30rpx 30rpx;
  background: linear-gradient(135deg, #ff6b35, #ff9a6c);
  color: #fff;
}
.header-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}
.header-sub {
  display: block;
  font-size: 26rpx;
  opacity: 0.85;
}

/* 工具网格 */
.tool-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 24rpx 20rpx;
  gap: 20rpx;
  margin-top: -30rpx;
}
.tool-card {
  width: calc(50% - 10rpx);
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
  box-sizing: border-box;
}
.tool-icon {
  font-size: 56rpx;
  margin-bottom: 16rpx;
}
.tool-name {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}
.tool-desc {
  display: block;
  font-size: 22rpx;
  color: #999;
}

/* 区块 */
.section {
  margin: 24rpx 30rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
}
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}
.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}
.section-more {
  font-size: 24rpx;
  color: #ff6b35;
}

/* 活动卡片 */
.activity-card {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #fafafa;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}
.activity-info { flex: 1; }
.activity-name {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}
.activity-meta {
  display: block;
  font-size: 22rpx;
  color: #999;
}
.activity-stats {
  text-align: center;
  margin: 0 20rpx;
}
.stat-label {
  display: block;
  font-size: 20rpx;
  color: #999;
  margin-bottom: 4rpx;
}
.stat-val {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}
.activity-status {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  background: #fff3ee;
  color: #ff6b35;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 40rpx;
}
.empty-icon { font-size: 80rpx; display: block; margin-bottom: 20rpx; }
.empty-text { font-size: 28rpx; color: #999; display: block; margin-bottom: 24rpx; }
.empty-btn {
  display: inline-block;
  padding: 16rpx 48rpx;
  background: #ff6b35;
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
}

/* GEO数据 */
.geo-summary {
  display: flex;
  justify-content: space-around;
  margin-bottom: 20rpx;
}
.geo-item { text-align: center; }
.geo-num {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: #ff6b35;
  margin-bottom: 8rpx;
}
.geo-label {
  display: block;
  font-size: 22rpx;
  color: #999;
}
.geo-tip {
  background: #fff9e6;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 24rpx;
  color: #996600;
  text-align: center;
}

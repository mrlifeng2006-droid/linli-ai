/* pages/home/home.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 20rpx;
}

/* 搜索栏 */
.search-bar {
  padding: 20rpx 30rpx;
  background: #ff6b35;
}
.search-input {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 36rpx;
  padding: 16rpx 30rpx;
  height: 72rpx;
  box-sizing: border-box;
}
.search-icon {
  font-size: 28rpx;
  margin-right: 16rpx;
}
.search-placeholder {
  color: #999;
  font-size: 26rpx;
}

/* Banner轮播 */
.banner {
  height: 300rpx;
  margin: 24rpx 30rpx;
  border-radius: 16rpx;
  overflow: hidden;
}
.banner-item {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  color: #fff;
}
.banner-1 { background: linear-gradient(135deg, #ff6b35, #ff9a6c); }
.banner-2 { background: linear-gradient(135deg, #4facfe, #00f2fe); }
.banner-3 { background: linear-gradient(135deg, #667eea, #764ba2); }
.banner-title {
  font-size: 44rpx;
  font-weight: bold;
  margin-bottom: 12rpx;
}
.banner-sub {
  font-size: 26rpx;
  opacity: 0.9;
}

/* 快捷导航 */
.quick-nav {
  display: flex;
  justify-content: space-around;
  padding: 30rpx 30rpx 10rpx;
  background: #fff;
}
.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.nav-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-bottom: 12rpx;
}
.nav-ai { background: #fff3ee; }
.nav-merchant { background: #eef6ff; }
.nav-marketing { background: #fff9e6; }
.nav-dist { background: #f0fff0; }
.nav-text {
  font-size: 24rpx;
  color: #333;
}

/* 区块通用 */
.section {
  background: #fff;
  margin: 24rpx 30rpx;
  border-radius: 16rpx;
  padding: 30rpx;
}
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}
.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}
.section-more {
  font-size: 24rpx;
  color: #999;
}

/* 商家卡片 */
.merchant-list { display: flex; flex-direction: column; gap: 20rpx; }
.merchant-card {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #fafafa;
  border-radius: 12rpx;
}
.merchant-info { flex: 1; }
.merchant-name {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}
.merchant-desc {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}
.merchant-tag {
  display: inline-block;
  font-size: 20rpx;
  background: #fff3ee;
  color: #ff6b35;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}
.merchant-action {
  font-size: 26rpx;
  color: #ff6b35;
  font-weight: bold;
}

/* 活动卡片 */
.activity-list { display: flex; flex-direction: column; gap: 16rpx; }
.activity-card {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #fafafa;
  border-radius: 12rpx;
}
.activity-left { flex: 1; }
.activity-name {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}
.activity-desc {
  display: block;
  font-size: 24rpx;
  color: #999;
}
.activity-tag {
  font-size: 22rpx;
  color: #ff6b35;
}

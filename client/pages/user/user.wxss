/* pages/user/user.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
}

/* 用户信息区 */
.profile-section {
  position: relative;
}
.profile-bg {
  width: 100%;
  height: 280rpx;
  background: linear-gradient(135deg, #ff6b35, #ff9a6c);
}
.profile-content {
  position: absolute;
  top: 60rpx;
  left: 40rpx;
  right: 40rpx;
  display: flex;
  align-items: center;
}
.avatar-wrap {
  position: relative;
  margin-right: 30rpx;
}
.avatar {
  width: 120rpx;
  height: 120rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  border: 6rpx solid #fff;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.1);
}
.vip-badge {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 40rpx;
  height: 40rpx;
  background: #ffd700;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  border: 4rpx solid #fff;
}
.profile-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}
.username {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 8rpx;
}
.user-desc {
  font-size: 24rpx;
  color: rgba(255,255,255,0.85);
}
.user-desc.unlogin {
  color: rgba(255,255,255,0.9);
}

/* 数据统计卡片 */
.stats-card {
  margin: -40rpx 30rpx 0;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
  position: relative;
  z-index: 1;
}
.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.stat-num {
  font-size: 40rpx;
  font-weight: bold;
  color: #ff6b35;
  margin-bottom: 6rpx;
}
.stat-label {
  font-size: 22rpx;
  color: #999;
}
.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: #eee;
}

/* 功能菜单 */
.menu-section {
  margin: 30rpx 30rpx;
}
.menu-title {
  font-size: 28rpx;
  color: #999;
  font-weight: 500;
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}
.menu-title.mt30 {
  margin-top: 30rpx;
}
.menu-list {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}
.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f5f5f5;
}
.menu-item:last-child { border-bottom: none; }
.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}
.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}
.menu-text.logout-text {
  color: #ff4444;
}
.menu-arrow {
  font-size: 32rpx;
  color: #ccc;
}
.logout-item {
  background: #fff;
}

/* 版本信息 */
.version-info {
  text-align: center;
  padding: 40rpx;
  font-size: 22rpx;
  color: #ccc;
}

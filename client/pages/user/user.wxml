<!--pages/user/user.wxml-->
<view class="container">
  <!-- 用户信息区 -->
  <view class="profile-section">
    <view class="profile-bg"></view>
    <view class="profile-content">
      <view class="avatar-wrap">
        <view class="avatar">👤</view>
        <view class="vip-badge" wx:if="{{isVip}}">⭐</view>
      </view>
      <view class="profile-info">
        <text class="username">{{isLogin ? username : '未登录'}}</text>
        <text class="user-desc" wx:if="{{isLogin}}">邻里AI会员</text>
        <text class="user-desc" wx:else bindtap="goToLogin">点击登录账号 ›</text>
      </view>
    </view>
  </view>

  <!-- 积分/权益卡片 -->
  <view class="stats-card">
    <view class="stat-item">
      <text class="stat-num">{{points || 0}}</text>
      <text class="stat-label">积分</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num">{{contentCount || 0}}</text>
      <text class="stat-label">已生成</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num">{{favorites || 0}}</text>
      <text class="stat-label">收藏</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num">{{history || 0}}</text>
      <text class="stat-label">历史</text>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section">
    <view class="menu-title">📌 我的功能</view>

    <view class="menu-list">
      <view class="menu-item" bindtap="goToHistory">
        <view class="menu-left">
          <text class="menu-icon">📝</text>
          <text class="menu-text">生成历史</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="goToFavorites">
        <view class="menu-left">
          <text class="menu-icon">⭐</text>
          <text class="menu-text">我的收藏</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="goToTemplates">
        <view class="menu-left">
          <text class="menu-icon">📐</text>
          <text class="menu-text">文案模板库</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="goToMyMerchant" wx:if="{{isMerchant}}">
        <view class="menu-left">
          <text class="menu-icon">🏪</text>
          <text class="menu-text">我的商家</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>
    </view>

    <view class="menu-title" style="margin-top: 30rpx;">⚙️ 设置</view>

    <view class="menu-list">
      <view class="menu-item" bindtap="goToSettings">
        <view class="menu-left">
          <text class="menu-icon">⚙️</text>
          <text class="menu-text">账号设置</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="goToAbout">
        <view class="menu-left">
          <text class="menu-icon">ℹ️</text>
          <text class="menu-text">关于我们</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="onLogout" wx:if="{{isLogin}}">
        <view class="menu-left">
          <text class="menu-icon">🚪</text>
          <text class="menu-text logout">退出登录</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 版本信息 -->
  <view class="version-info">
    <text>邻里AI V17.0</text>
  </view>
</view>

<!--pages/user/user.wxml-->
<view class="container">

  <!-- 用户信息区 -->
  <view class="profile-section">
    <view class="profile-bg"></view>
    <view class="profile-content">
      <view class="avatar-wrap">
        <view class="avatar">👤</view>
        <view class="vip-badge" wx:if="{{isVip}}">⭐</view>
      </view>
      <view class="profile-info">
        <text class="username">{{username || '未登录'}}</text>
        <text class="user-desc" wx:if="{{isLogin}}">邻里AI会员</text>
        <text class="user-desc unlogin" wx:if="{{!isLogin}}" bindtap="goToLogin">点击登录账号 ›</text>
      </view>
    </view>
  </view>

  <!-- 积分/权益卡片 -->
  <view class="stats-card">
    <view class="stat-item">
      <text class="stat-num">{{points}}</text>
      <text class="stat-label">积分</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num">{{contentCount}}</text>
      <text class="stat-label">已生成</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num">{{favorites}}</text>
      <text class="stat-label">收藏</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num">{{browseCount}}</text>
      <text class="stat-label">浏览</text>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section">
    <view class="menu-title">📌 我的功能</view>

    <view class="menu-list">
      <view class="menu-item" bindtap="goToHistory">
        <text class="menu-icon">📝</text>
        <text class="menu-text">生成历史</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="goToFavorites">
        <text class="menu-icon">⭐</text>
        <text class="menu-text">我的收藏</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="goToTemplates">
        <text class="menu-icon">📐</text>
        <text class="menu-text">文案模板库</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" wx:if="{{isMerchant}}" bindtap="goToMyMerchant">
        <text class="menu-icon">🏪</text>
        <text class="menu-text">我的商家</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>

    <view class="menu-title mt30">⚙️ 设置</view>

    <view class="menu-list">
      <view class="menu-item" bindtap="goToSettings">
        <text class="menu-icon">⚙️</text>
        <text class="menu-text">账号设置</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="goToAbout">
        <text class="menu-icon">ℹ️</text>
        <text class="menu-text">关于我们</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item logout-item" wx:if="{{isLogin}}" bindtap="onLogout">
        <text class="menu-icon">🚪</text>
        <text class="menu-text logout-text">退出登录</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 版本信息 -->
  <view class="version-info">
    <text>邻里AI V17.0</text>
  </view>

</view>

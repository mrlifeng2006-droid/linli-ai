/* pages/register/register.wxss */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF3E0 0%, #FFFFFF 40%);
  padding: 0 50rpx;
}

/* 顶部标题 */
.header-section {
  padding-top: 80rpx;
  padding-bottom: 50rpx;
}

.header-title {
  display: block;
  font-size: 52rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 16rpx;
}

.header-sub {
  display: block;
  font-size: 28rpx;
  color: #999999;
}

/* 表单区 */
.form-section {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 50rpx 40rpx;
  box-shadow: 0 4rpx 30rpx rgba(0, 0, 0, 0.06);
}

.form-item {
  margin-bottom: 36rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.optional {
  font-size: 24rpx;
  color: #BBBBBB;
  font-weight: normal;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background: #F5F5F5;
  border-radius: 16rpx;
  padding: 0 30rpx;
  font-size: 32rpx;
  box-sizing: border-box;
}

.code-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.code-input {
  flex: 1;
}

.code-btn {
  flex-shrink: 0;
  width: 220rpx;
  height: 88rpx;
  background: linear-gradient(135deg, #FF8C00, #FF6B00);
  color: white;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 500;
}

.code-btn:active { opacity: 0.85; }
.code-btn.disabled { background: #CCCCCC; }

/* 注册按钮 */
.register-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #FF8C00, #FF6B00);
  color: white;
  border-radius: 48rpx;
  font-size: 34rpx;
  font-weight: bold;
  border: none;
  box-shadow: 0 6rpx 24rpx rgba(255, 107, 0, 0.35);
  margin-top: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.register-btn::after { border: none; }
.register-btn[disabled] {
  background: #CCCCCC;
  box-shadow: none;
  color: white;
}

/* 登录入口 */
.login-link {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-top: 40rpx;
  font-size: 28rpx;
  color: #999999;
}

.link {
  color: #FF6B00;
  margin: 0 6rpx;
}

/* 协议 */
.agreement {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-top: 40rpx;
  padding-bottom: 60rpx;
  font-size: 24rpx;
  color: #BBBBBB;
}

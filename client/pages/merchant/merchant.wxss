/* pages/merchant/merchant.wxss */
page {
  background: #f5f5f5;
  min-height: 100vh;
}

.container {
  padding: 0 0 40rpx 0;
}

/* ==== 未入驻状态 ==== */
.header-bar {
  background: linear-gradient(135deg, #FF6B00, #FF8C00);
  color: white;
  padding: 40rpx 32rpx 32rpx;
}

.header-title {
  font-size: 44rpx;
  font-weight: 700;
  display: block;
}

.header-sub {
  font-size: 26rpx;
  opacity: 0.9;
  margin-top: 8rpx;
  display: block;
}

.form-card {
  margin: 24rpx;
  background: white;
  border-radius: 16rpx;
  padding: 32rpx;
}

.form-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-item {
  margin-bottom: 28rpx;
}

.form-label {
  font-size: 28rpx;
  color: #666;
  display: block;
  margin-bottom: 10rpx;
}

.form-input {
  background: #f8f8f8;
  border-radius: 10rpx;
  padding: 16rpx 20rpx;
  font-size: 30rpx;
  border: 1rpx solid #e8e8e8;
  min-height: 44rpx;
}

.form-picker {
  background: #f8f8f8;
  border-radius: 10rpx;
  padding: 16rpx 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border: 1rpx solid #e8e8e8;
}

.picker-arrow {
  font-size: 32rpx;
  color: #999;
}

.form-hint {
  font-size: 22rpx;
  color: #aaa;
  margin-top: 8rpx;
  display: block;
}

.location-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.location-info {
  flex: 1;
}

.location-coord {
  font-size: 24rpx;
  color: #FF6B00;
}

.btn-location {
  background: #FFF3E0;
  color: #FF6B00;
  border: 1rpx solid #FFB74D;
  border-radius: 8rpx;
  font-size: 24rpx;
  padding: 0 20rpx;
}

.btn-area {
  padding: 0 32rpx;
  margin-top: 8rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #FF6B00, #FF8C00);
  color: white;
  border-radius: 48rpx;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 34rpx;
  font-weight: 600;
  border: none;
}

.benefit-list {
  margin: 32rpx 32rpx 0;
  background: white;
  border-radius: 16rpx;
  padding: 24rpx 32rpx;
}

.benefit-item {
  font-size: 28rpx;
  color: #555;
  padding: 10rpx 0;
}

/* ==== 加载中 ==== */
.loading-state {
  text-align: center;
  padding: 100rpx;
  color: #999;
  font-size: 28rpx;
}

/* ==== 已入驻状态 ==== */
.merchant-card {
  background: linear-gradient(135deg, #FF6B00, #FF8C00);
  color: white;
  padding: 32rpx;
  margin: 24rpx;
  border-radius: 16rpx;
}

.merchant-name {
  font-size: 40rpx;
  font-weight: 700;
}

.merchant-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 12rpx;
  flex-wrap: wrap;
}

.meta-tag {
  background: rgba(255,255,255,0.2);
  border-radius: 6rpx;
  padding: 4rpx 12rpx;
  font-size: 22rpx;
}

.meta-badge {
  background: #4CAF50;
  color: white;
  border-radius: 6rpx;
  padding: 4rpx 12rpx;
  font-size: 22rpx;
}

.meta-badge.pending {
  background: #FF9800;
}

.merchant-stats-row {
  display: flex;
  margin-top: 24rpx;
  gap: 0;
}

.mini-stat {
  flex: 1;
  text-align: center;
}

.mini-num {
  font-size: 36rpx;
  font-weight: 700;
  display: block;
}

.mini-label {
  font-size: 22rpx;
  opacity: 0.85;
  display: block;
  margin-top: 4rpx;
}

/* GEO看板 */
.section {
  margin: 0 24rpx 24rpx;
  background: white;
  border-radius: 16rpx;
  padding: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.geo-grid {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.geo-card {
  flex: 1;
  background: #FFF3E0;
  border-radius: 12rpx;
  padding: 20rpx 12rpx;
  text-align: center;
}

.geo-num {
  font-size: 36rpx;
  font-weight: 700;
  color: #FF6B00;
  display: block;
}

.geo-label {
  font-size: 22rpx;
  color: #888;
  display: block;
  margin-top: 4rpx;
}

.btn-small {
  background: #FFF3E0;
  color: #FF6B00;
  border: 1rpx solid #FFB74D;
  border-radius: 8rpx;
  font-size: 26rpx;
  padding: 8rpx 24rpx;
  display: inline-block;
}

/* Tab */
.tab-bar {
  display: flex;
  background: white;
  margin: 0 24rpx;
  border-radius: 12rpx 12rpx 0 0;
  overflow: hidden;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #999;
  border-bottom: 4rpx solid transparent;
}

.tab-item text {
  display: block;
}

.tab-item.active {
  color: #FF6B00;
  border-bottom-color: #FF6B00;
}

.tab-content {
  background: white;
  margin: 0 24rpx 24rpx;
  border-radius: 0 0 16rpx 16rpx;
  padding: 24rpx;
  min-height: 200rpx;
}

/* 信息列表 */
.info-list {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #888;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.info-value.green {
  color: #4CAF50;
}

.info-value.orange {
  color: #FF9800;
}

/* 统计数据 */
.stats-card {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.stat-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.stat-row:last-child {
  border-bottom: none;
}

.stat-label {
  font-size: 28rpx;
  color: #888;
}

.stat-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.stat-value.primary {
  color: #FF6B00;
}

.stat-value.green {
  color: #4CAF50;
}

.btn-refresh {
  margin-top: 24rpx;
  background: #FFF3E0;
  color: #FF6B00;
  border: 1rpx solid #FFB74D;
  border-radius: 12rpx;
  font-size: 28rpx;
}

/* 店员 */
.staff-intro {
  font-size: 26rpx;
  color: #888;
  margin-bottom: 24rpx;
  line-height: 1.6;
}

.btn-invite {
  background: linear-gradient(135deg, #FF6B00, #FF8C00);
  color: white;
  border-radius: 12rpx;
  font-size: 30rpx;
  height: 96rpx;
  line-height: 96rpx;
  border: none;
}

.staff-limit-hint {
  font-size: 22rpx;
  color: #aaa;
  text-align: center;
  margin-top: 16rpx;
}

.empty-state {
  text-align: center;
  color: #bbb;
  font-size: 28rpx;
  padding: 60rpx 0;
}

/* 快捷入口 */
.quick-actions {
  display: flex;
  gap: 16rpx;
  margin: 0 24rpx;
}

.action-item {
  flex: 1;
  background: white;
  border-radius: 12rpx;
  padding: 24rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.action-icon {
  font-size: 40rpx;
}

.action-text {
  font-size: 26rpx;
  color: #666;
}

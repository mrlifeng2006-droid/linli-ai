/* pages/distribution/distribution.wxss */
page {
  background: #f5f5f5;
  min-height: 100vh;
}

.container {
  padding-bottom: 40rpx;
}

/* === 顶部标题 === */
.header {
  background: linear-gradient(135deg, #FF6B00, #FF8C00);
  color: white;
  padding: 36rpx 32rpx 28rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  display: block;
}

.header-sub {
  font-size: 26rpx;
  opacity: 0.9;
  margin-top: 6rpx;
  display: block;
}

/* === Tab === */
.tab-bar {
  display: flex;
  background: white;
  margin: 20rpx 24rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #999;
  border-bottom: 4rpx solid transparent;
}

.tab-item.active {
  color: #FF6B00;
  border-bottom-color: #FF6B00;
}

.tab-content {
  margin: 0 24rpx;
  background: white;
  border-radius: 16rpx;
  padding: 24rpx;
  min-height: 500rpx;
}

/* === 内容预览 === */
.content-preview {
  margin-bottom: 24rpx;
}

.preview-title {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.preview-item {
  background: #f8f8f8;
  border-radius: 10rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 12rpx;
}

.preview-type {
  font-size: 22rpx;
  color: #FF6B00;
  background: #FFF3E0;
  border-radius: 6rpx;
  padding: 4rpx 12rpx;
  display: inline-block;
  margin-bottom: 8rpx;
}

.preview-text {
  font-size: 26rpx;
  color: #333;
  line-height: 1.6;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
}

.preview-tags {
  font-size: 22rpx;
  color: #888;
  margin-top: 6rpx;
  display: block;
}

/* === 空状态 === */
.empty-hint {
  text-align: center;
  padding: 60rpx 0;
  color: #bbb;
  font-size: 28rpx;
}

.btn-goto-generate {
  margin-top: 20rpx;
  background: #FFF3E0;
  color: #FF6B00;
  border: 1rpx solid #FFB74D;
  border-radius: 10rpx;
  font-size: 28rpx;
}

/* === 平台选择 === */
.platform-section {
  margin-top: 20rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.platform-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.platform-card {
  background: #f8f8f8;
  border-radius: 14rpx;
  padding: 20rpx 16rpx;
  border: 2rpx solid #eee;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  position: relative;
  transition: all 0.2s;
}

.platform-card.selected {
  background: #FFF9F4;
}

.platform-card.copied {
  background: #F0FFF0;
  border-color: #4CAF50 !important;
}

.platform-icon {
  font-size: 40rpx;
}

.platform-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.platform-tip {
  font-size: 20rpx;
  color: #aaa;
  text-align: center;
  line-height: 1.4;
}

.platform-status {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  background: #4CAF50;
  color: white;
  border-radius: 6rpx;
  font-size: 18rpx;
  padding: 2rpx 8rpx;
}

/* === 发布按钮 === */
.action-area {
  margin-top: 24rpx;
}

.selected-platform-hint {
  font-size: 24rpx;
  color: #888;
  text-align: center;
  margin-bottom: 12rpx;
}

.hint-platform {
  color: #FF6B00;
  font-weight: 600;
}

.btn-publish {
  background: linear-gradient(135deg, #FF6B00, #FF8C00);
  color: white;
  border-radius: 48rpx;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 34rpx;
  font-weight: 600;
  border: none;
}

.btn-publish.btn-copied {
  background: #4CAF50;
}

/* === 提示卡片 === */
.tips-card {
  margin-top: 24rpx;
  background: #FFF9F4;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
}

.tips-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #FF6B00;
  margin-bottom: 10rpx;
}

.tips-item {
  font-size: 24rpx;
  color: #888;
  line-height: 1.8;
}

/* === 分发历史 === */
.history-stats {
  margin-bottom: 16rpx;
}

.stats-text {
  font-size: 24rpx;
  color: #999;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.history-card {
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 18rpx 20rpx;
}

.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.platform-badge {
  color: white;
  border-radius: 6rpx;
  padding: 4rpx 12rpx;
  font-size: 22rpx;
}

.history-time {
  font-size: 22rpx;
  color: #aaa;
}

.history-content {
  font-size: 26rpx;
  color: #555;
  line-height: 1.5;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  margin-bottom: 10rpx;
}

.history-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.history-meta {
  display: flex;
  gap: 16rpx;
}

.history-meta text {
  font-size: 22rpx;
  color: #aaa;
}

.history-copy-btn {
  font-size: 24rpx;
  color: #FF6B00;
}

.empty-state {
  text-align: center;
  padding: 80rpx 0;
  color: #bbb;
}

.empty-sub {
  font-size: 24rpx;
  color: #ccc;
  margin-top: 10rpx;
  display: block;
}

.loading-more {
  text-align: center;
  color: #aaa;
  font-size: 26rpx;
  padding: 20rpx 0;
}

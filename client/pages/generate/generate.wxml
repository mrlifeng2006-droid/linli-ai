<!--pages/generate/generate.wxml —— 2026-04-20 v3：零表单，自动读取商家信息-->
<view class="container">
  <!-- 标题区 -->
  <view class="header">
    <text class="header-title">🤖 AI智能生成</text>
    <text class="header-sub">基于您的店铺信息，AI自动生成营销文案</text>
  </view>

  <!-- 加载中 -->
  <view class="loading-card" wx:if="{{loadingMerchant}}">
    <text class="loading-icon">⏳</text>
    <text class="loading-text">正在加载店铺信息...</text>
  </view>

  <!-- 加载失败 -->
  <view class="error-card" wx:if="{{merchantError}}">
    <text class="error-icon">⚠️</text>
    <text class="error-text">加载失败，请检查网络</text>
    <button class="retry-btn" bindtap="retryLoad">重新加载</button>
  </view>

  <!-- 商家信息卡片（只读展示） -->
  <view class="merchant-card" wx:if="{{!loadingMerchant && !merchantError && merchant}}">
    <view class="merchant-header">
      <text class="merchant-name">{{merchant.store_name}}</text>
      <view class="merchant-tag">{{merchant.industry_cat}}</view>
    </view>
    <view class="merchant-info">
      <text class="info-item" wx:if="{{merchant.location_text}}">📍 {{merchant.location_text}}</text>
      <text class="info-item" wx:if="{{merchant.features}}">🎯 {{merchant.features}}</text>
      <text class="info-item" wx:if="{{merchant.target_customer}}">👥 目标客户：{{merchant.target_customer}}</text>
    </view>
    <view class="merchant-edit" bindtap="goToOnboarding">
      <text class="edit-text">修改店铺信息</text>
      <text class="edit-arrow">›</text>
    </view>
  </view>

  <!-- 生成选项 -->
  <view class="form-card" wx:if="{{!loadingMerchant && !merchantError && merchant}}">
    <view class="form-title">⚙️ 生成选项</view>

    <view class="form-item">
      <text class="form-label">内容类型</text>
      <view class="checkbox-group">
        <view class="checkbox-item {{checkedTypes.social ? 'checked' : ''}}" bindtap="toggleType" data-type="social">
          <text class="checkbox-icon">{{checkedTypes.social ? '✓' : ''}}</text>
          <text>朋友圈文案</text>
        </view>
        <view class="checkbox-item {{checkedTypes.shortVideo ? 'checked' : ''}}" bindtap="toggleType" data-type="shortVideo">
          <text class="checkbox-icon">{{checkedTypes.shortVideo ? '✓' : ''}}</text>
          <text>短视频脚本</text>
        </view>
        <view class="checkbox-item {{checkedTypes.poster ? 'checked' : ''}}" bindtap="toggleType" data-type="poster">
          <text class="checkbox-icon">{{checkedTypes.poster ? '✓' : ''}}</text>
          <text>海报文案</text>
        </view>
        <view class="checkbox-item {{checkedTypes.groupMsg ? 'checked' : ''}}" bindtap="toggleType" data-type="groupMsg">
          <text class="checkbox-icon">{{checkedTypes.groupMsg ? '✓' : ''}}</text>
          <text>群发消息</text>
        </view>
      </view>
    </view>

    <view class="form-item">
      <text class="form-label">文案风格</text>
      <view class="style-group">
        <view class="style-item {{selectedStyle === 'friendly' ? 'active' : ''}}" bindtap="selectStyle" data-style="friendly">😊 亲切</view>
        <view class="style-item {{selectedStyle === 'professional' ? 'active' : ''}}" bindtap="selectStyle" data-style="professional">💼 专业</view>
        <view class="style-item {{selectedStyle === 'casual' ? 'active' : ''}}" bindtap="selectStyle" data-style="casual">😎 轻松</view>
        <view class="style-item {{selectedStyle === 'humor' ? 'active' : ''}}" bindtap="selectStyle" data-style="humor">😂 幽默</view>
      </view>
    </view>
  </view>

  <!-- 图片上传 -->
  <view class="form-card" wx:if="{{!loadingMerchant && !merchantError && merchant}}">
    <view class="form-title">🖼️ 上传店铺图片（可选）</view>
    <view class="form-sub">AI将分析图片内容，生成更精准的配图文案，最多9张</view>
    <view class="image-upload-area">
      <view class="image-list">
        <view class="image-item" wx:for="{{uploadedImages}}" wx:key="index">
          <image class="uploaded-img" src="{{item}}" mode="aspectFill" />
          <view class="img-delete" bindtap="deleteImage" data-index="{{index}}">✕</view>
        </view>
        <view class="image-add" bindtap="chooseImage" wx:if="{{uploadedImages.length < 9}}">
          <text class="add-icon">+</text>
          <text class="add-text">添加图片</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 一键生成按钮 -->
  <view class="generate-btn-wrap" wx:if="{{!loadingMerchant && !merchantError && merchant}}">
    <view class="compress-progress" wx:if="{{compressProgress}}">
      <text>{{compressProgress}}</text>
    </view>
    <view class="generate-btn {{generating ? 'loading' : ''}}" bindtap="onGenerate">
      <text class="btn-icon">✨</text>
      <text class="btn-text">{{generating ? 'AI生成中...' : '开始生成'}}</text>
    </view>
    <text class="generate-tip">* AI将自动注入GEO定位信息，让内容更具本地曝光效果</text>
  </view>
</view>

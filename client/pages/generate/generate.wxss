/* pages/generate/generate.wxss */
page {
  width: 100%;
  box-sizing: border-box;
}

.container {
  width: 100%;
  min-height: 100vh;
  background: #f5f5f5;
  padding: 30rpx;
  padding-bottom: 220rpx;
  box-sizing: border-box;
  overflow-x: hidden;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

/* 头部 */
.header {
  width: 100%;
  text-align: center;
  padding: 20rpx 0 30rpx;
  box-sizing: border-box;
}
.header-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}
.header-sub {
  display: block;
  font-size: 26rpx;
  color: #999;
}

/* 表单卡片 */
.form-card {
  width: 100%;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-sizing: border-box;
}
.form-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #ff6b35;
}

/* 表单项 */
.form-item {
  width: 100%;
  margin-bottom: 30rpx;
  box-sizing: border-box;
}
.form-item:last-child { margin-bottom: 0; }

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 12rpx;
}

/* 输入框 - 使用固定宽度策略避免百分比重叠问题 */
.form-input {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  border: none;
  border-bottom: 2rpx solid #eee;
  background: #fafafa;
  font-size: 28rpx;
  color: #333;
  padding: 0 16rpx;
  box-sizing: border-box;
}
.form-textarea {
  width: 100%;
  min-height: 140rpx;
  border: none;
  border-bottom: 2rpx solid #eee;
  background: #fafafa;
  font-size: 28rpx;
  color: #333;
  padding: 16rpx;
  box-sizing: border-box;
  line-height: 1.6;
}

/* Picker选择器 */
.form-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  width: 100%;
  height: 80rpx;
  border-bottom: 2rpx solid #eee;
  background: #fafafa;
  padding: 0 16rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #333;
}
.picker-arrow {
  font-size: 32rpx;
  color: #ccc;
  transform: rotate(90deg);
}
.placeholder { color: #999; }

/* 多选框 */
.checkbox-group {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.checkbox-item {
  display: flex;
  align-items: center;
  padding: 14rpx 24rpx;
  border: 2rpx solid #eee;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #666;
  background: #fafafa;
  box-sizing: border-box;
}
.checkbox-item.checked {
  border-color: #ff6b35;
  color: #ff6b35;
  background: #fff3ee;
}
.checkbox-icon {
  margin-right: 8rpx;
  font-size: 22rpx;
  width: 28rpx;
  display: inline-block;
}

/* 文案风格选择 */
.style-group {
  display: flex;
  gap: 16rpx;
}
.style-item {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  border: 2rpx solid #eee;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #666;
  background: #fafafa;
  box-sizing: border-box;
}
.style-item.active {
  border-color: #ff6b35;
  color: #ff6b35;
  background: #fff3ee;
}

/* 生成按钮 */
.generate-btn-wrap {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  padding: 20rpx 30rpx calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.06);
  box-sizing: border-box;
  z-index: 100;
}
.generate-btn {
  width: 100%;
  background: linear-gradient(135deg, #ff6b35, #ff9a6c);
  border-radius: 50rpx;
  padding: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}
.generate-btn.loading {
  opacity: 0.7;
}
.btn-icon { font-size: 36rpx; }
.btn-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
}
/* 图片压缩进度 */
.compress-progress {
  text-align: center;
  font-size: 26rpx;
  color: #ff6b35;
  padding: 10rpx 0 6rpx;
  animation: blink 1.5s infinite;
}
@keyframes blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}
.generate-tip {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: #bbb;
  margin-top: 12rpx;
}

/* 图片上传 */
.form-sub {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 16rpx;
}
.image-upload-area {
  width: 100%;
}
.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.image-item {
  width: 200rpx;
  height: 200rpx;
  position: relative;
  border-radius: 16rpx;
  overflow: hidden;
}
.uploaded-img {
  width: 100%;
  height: 100%;
}
.img-delete {
  position: absolute;
  top: 0;
  right: 0;
  width: 44rpx;
  height: 44rpx;
  background: rgba(0,0,0,0.5);
  color: #fff;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 0 0 0 12rpx;
}
.image-add {
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed #ccc;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #fafafa;
}
.add-icon {
  font-size: 60rpx;
  color: #ccc;
  line-height: 1;
}
.add-text {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 加载中卡片 */
.loading-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 60rpx 30rpx;
  text-align: center;
  margin-bottom: 24rpx;
}
.loading-icon {
  font-size: 48rpx;
  display: block;
  margin-bottom: 16rpx;
}
.loading-text {
  font-size: 28rpx;
  color: #666;
}

/* 错误卡片 */
.error-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 60rpx 30rpx;
  text-align: center;
  margin-bottom: 24rpx;
}
.error-icon {
  font-size: 48rpx;
  display: block;
  margin-bottom: 16rpx;
}
.error-text {
  font-size: 28rpx;
  color: #666;
  display: block;
  margin-bottom: 24rpx;
}
.retry-btn {
  display: inline-block;
  padding: 16rpx 48rpx;
  background: #07c160;
  color: #fff;
  font-size: 28rpx;
  border-radius: 32rpx;
  border: none;
}
.retry-btn::after {
  border: none;
}

/* 商家信息卡片 */
.merchant-card {
  background: linear-gradient(135deg, #07c160 0%, #10b981 100%);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  color: #fff;
}
.merchant-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}
.merchant-name {
  font-size: 36rpx;
  font-weight: 600;
}
.merchant-tag {
  font-size: 22rpx;
  background: rgba(255,255,255,0.2);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}
.merchant-info {
  margin-bottom: 20rpx;
}
.info-item {
  display: block;
  font-size: 26rpx;
  opacity: 0.9;
  margin-bottom: 12rpx;
  line-height: 1.5;
}
.merchant-edit {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(255,255,255,0.2);
}
.edit-text {
  font-size: 26rpx;
  opacity: 0.9;
}
.edit-arrow {
  font-size: 32rpx;
  margin-left: 8rpx;
  opacity: 0.9;
}
